rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: only authenticated users can read user documents.
    match /users/{userId} {
      allow read: if request.auth != null;

      // Optional: only allow users to write their own user doc.
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Posts collection: only authenticated users can read.
    match /posts/{postId} {
      allow read: if request.auth != null;

      // Only the author can create/update/delete their own posts.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
  }
}
